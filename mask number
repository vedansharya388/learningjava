import java.util.Scanner;
import java.util.regex.Pattern;
import java.util.regex.Matcher;

public class PhoneNumberMasker {
    
    // Method to mask phone number (show last 4 digits)
    public static String maskPhoneNumber(String phoneNumber) {
        if (phoneNumber == null || phoneNumber.trim().isEmpty()) {
            return "Invalid number";
        }
        
        // Remove all non-digit characters
        String cleanNumber = phoneNumber.replaceAll("[^0-9]", "");
        
        // Check if number has at least 7 digits (for masking)
        if (cleanNumber.length() < 7) {
            return "Number too short";
        }
        
        // Mask all digits except last 4
        StringBuilder masked = new StringBuilder();
        for (int i = 0; i < cleanNumber.length() - 4; i++) {
            masked.append("*");
        }
        masked.append(cleanNumber.substring(cleanNumber.length() - 4));
        
        return masked.toString();
    }
    
    // Method to validate Chinese phone number
    public static boolean isValidChinesePhone(String phoneNumber) {
        String regex = "^1[3-9]\\d{9}$";
        Pattern pattern = Pattern.compile(regex);
        Matcher matcher = pattern.matcher(phoneNumber.replaceAll("[^0-9]", ""));
        return matcher.matches();
    }
    
    // Method for batch masking
    public static void batchMaskNumbers(String[] phoneNumbers) {
        System.out.println("\n=== Batch Masking Results ===");
        for (int i = 0; i < phoneNumbers.length; i++) {
            System.out.printf("%d. %s → %s%n", 
                i + 1, 
                phoneNumbers[i], 
                maskPhoneNumber(phoneNumbers[i])
            );
        }
    }
    
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        int choice;
        
        System.out.println("🎭 PHONE NUMBER MASKER 🎭");
        System.out.println("=========================");
        
        do {
            System.out.println("\n📱 Choose an option:");
            System.out.println("1. Mask single phone number");
            System.out.println("2. Validate Chinese phone number");
            System.out.println("3. Batch mask multiple numbers");
            System.out.println("4. Exit");
            System.out.print("Enter choice (1-4): ");
            
            choice = scanner.nextInt();
            scanner.nextLine(); // consume newline
            
            switch (choice) {
                case 1:
                    System.out.print("\nEnter phone number: ");
                    String singleNumber = scanner.nextLine();
                    String masked = maskPhoneNumber(singleNumber);
                    System.out.printf("Masked: %s%n", masked);
                    break;
                    
                case 2:
                    System.out.print("\nEnter phone number to validate: ");
                    String phoneToValidate = scanner.nextLine();
                    boolean isValid = isValidChinesePhone(phoneToValidate);
                    System.out.printf("Valid Chinese phone: %s%n", isValid ? "✅ YES" : "❌ NO");
                    break;
                    
                case 3:
                    System.out.print("\nHow many numbers to mask? ");
                    int count = scanner.nextInt();
                    scanner.nextLine();
                    
                    String[] numbers = new String[count];
                    System.out.println("Enter " + count + " phone numbers:");
                    for (int i = 0; i < count; i++) {
                        System.out.printf("Number %d: ", i + 1);
                        numbers[i] = scanner.nextLine();
                    }
                    batchMaskNumbers(numbers);
                    break;
                    
                case 4:
                    System.out.println("👋 Goodbye!");
                    break;
                    
                default:
                    System.out.println("❌ Invalid choice! Try 1-4.");
            }
        } while (choice != 4);
        
        scanner.close();
    }
}
